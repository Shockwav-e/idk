{
  "format_version": "1.8.0",
  "animations": {
    "animation.chim_marvel.spin": {
      "loop": true,
      "animation_length": 0.5,
      "bones": { "weapon": { "rotation": [0, 0, "q.life_time * 720"] } }
    },
    "animation.chim_marvel.pulse": {
      "loop": true,
      "animation_length": 1,
      "bones": { "weapon": { "scale": ["1 + math.sin(q.life_time * 360) * 0.15", "1 + math.sin(q.life_time * 360) * 0.15", "1 + math.sin(q.life_time * 360) * 0.15"] } }
    }
  }
}
