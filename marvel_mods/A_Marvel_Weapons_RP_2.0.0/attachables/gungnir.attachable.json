{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "chim_marvel:gungnir",
      "materials": { "default": "entity_alphatest", "enchanted": "entity_alphatest_glint" },
      "textures": { "default": "textures/items/gungnir", "enchanted": "textures/misc/enchanted_item_glint" },
      "geometry": { "default": "geometry.chim_marvel.gungnir" },
      "animations": {
        "first_person": "animation.chim_marvel.gungnir_first_person",
        "third_person": "animation.chim_marvel.gungnir_third_person",
        "use":          "animation.chim_marvel.gungnir_use",
        "swing":        "animation.chim_marvel.gungnir_swing"
      },
      "scripts": {
        "parent_setup": "variable.hat_layer_visible = 0.0;",
        "animate": [
          { "first_person": "c.is_first_person && !(q.swing_progress > 0.0)" },
          { "third_person": "!c.is_first_person" },
          { "use":   "c.is_first_person && q.is_using_item && q.is_sneaking" },
          { "swing": "c.is_first_person && q.swing_progress > 0.0" }
        ]
      },
      "render_controllers": ["controller.render.item_default"]
    }
  }
}
