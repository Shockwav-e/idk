      "mixed": "animation.chim_marvel.stormbreaker_mixed"
    },
    "scripts": { "animate": [
      { "vertical": "q.property('chim_marvel:spin_style') == 0" },
      { "horizontal": "q.property('chim_marvel:spin_style') == 1" },
      { "diagonal": "q.property('chim_marvel:spin_style') == 2" },
      { "mixed": "q.property('chim_marvel:spin_style') == 3" }
    ] },
    "render_controllers": ["controller.render.default"]
