{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.chim_marvel.cat_locomotion": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "animations": ["idle"],
          "transitions": [
            { "death": "!q.is_alive" },
            { "sit": "q.property('chim_marvel:is_sitting')" },
            { "attack": "q.has_target && q.modified_move_speed < 0.04" },
            { "walk": "q.modified_move_speed >= 0.04" }
          ]
        },
        "walk": {
          "animations": ["walk"],
          "transitions": [
            { "death": "!q.is_alive" },
            { "attack": "q.has_target && q.modified_move_speed < 0.04" },
            { "idle": "q.modified_move_speed < 0.04" }
          ]
        },
        "attack": {
          "animations": ["attack"],
          "transitions": [
            { "death": "!q.is_alive" },
            { "walk": "q.modified_move_speed >= 0.04" },
            { "idle": "!q.has_target" }
          ]
        },
        "sit": {
          "animations": ["sit"],
          "transitions": [
            { "death": "!q.is_alive" },
            { "idle": "!q.property('chim_marvel:is_sitting')" }
          ]
        },
        "death": { "animations": ["death"] }
      }
    },
    "controller.animation.chim_marvel.war_cat_locomotion": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "animations": ["idle"],
          "transitions": [
            { "death": "!q.is_alive" },
            { "attack": "q.has_target && q.modified_move_speed < 0.04" },
            { "walk": "q.modified_move_speed >= 0.04" }
          ]
        },
        "walk": {
          "animations": ["walk"],
          "transitions": [
            { "death": "!q.is_alive" },
            { "attack": "q.has_target && q.modified_move_speed < 0.04" },
            { "idle": "q.modified_move_speed < 0.04" }
          ]
        },
        "attack": {
          "animations": ["attack"],
          "transitions": [
            { "death": "!q.is_alive" },
            { "walk": "q.modified_move_speed >= 0.04" },
            { "idle": "!q.has_target" }
          ]
        },
        "death": { "animations": ["death"] }
      }
    }
  }
}
